generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/*
|--------------------------------------------------------------------------
| SUCURSAL
|--------------------------------------------------------------------------
*/

model Sucursal {
  id          String      @id @default(uuid())
  nombre      String
  direccion   String

  vehiculos   Vehiculo[]
  conductores Conductor[]

  usuarios    Usuario[]
}

/*
|--------------------------------------------------------------------------
| VEHICULO
|--------------------------------------------------------------------------
*/

model Vehiculo {
  id            String   @id @default(uuid())
  patente       String   @unique
  capacidad     Float
  estado        String

  documentacionVigente Boolean @default(true)
  mantencionVigente Boolean @default(true)

  sucursalId    String
  sucursal      Sucursal @relation(fields: [sucursalId], references: [id])

  asignaciones  Asignacion[]
}

/*
|--------------------------------------------------------------------------
| CONDUCTOR
|--------------------------------------------------------------------------
*/

model Conductor {
  id            String   @id @default(uuid())
  nombre        String
  estado        String

  documentacionVigente Boolean @default(true)

  sucursalId    String
  sucursal      Sucursal @relation(fields: [sucursalId], references: [id])

  usuario       Usuario?

  asignaciones  Asignacion[]
}

/*
|--------------------------------------------------------------------------
| SOLICITUD
|--------------------------------------------------------------------------
*/

model Solicitud {
  id               String   @id @default(uuid())
  cliente          String
  destino          String
  cargaRequerida   Float
  fechaLimite      DateTime
  estado           String

  // 🆕 nuevos campos
  descripcion      String?
  fechaCreacion    DateTime @default(now())

  fechaAprobacion  DateTime?
  aprobadoPor      String?

  fechaRechazo     DateTime?
  rechazadoPor     String?
  motivoRechazo    String?

  // relación 1:1 con Trabajo
  trabajo          Trabajo?
}

/*
|--------------------------------------------------------------------------
| TRABAJO
|--------------------------------------------------------------------------
*/

model Trabajo {
  id              String   @id @default(uuid())

  solicitudId     String   @unique
  solicitud       Solicitud @relation(fields: [solicitudId], references: [id])

  estadoOperativo String
  resultado       String?

  cargaTotal      Float
  cargaEntregada  Float

  asignaciones    Asignacion[]
}

/*
|--------------------------------------------------------------------------
| ASIGNACION
|--------------------------------------------------------------------------
*/

model Asignacion {
  id              String   @id @default(uuid())

  trabajoId       String
  trabajo         Trabajo  @relation(fields: [trabajoId], references: [id])

  vehiculoId      String
  vehiculo        Vehiculo @relation(fields: [vehiculoId], references: [id])

  conductorId     String
  conductor       Conductor @relation(fields: [conductorId], references: [id])

  estadoOperativo String
  resultado       String?

  // 🆕 NUEVO
  cargaAsignada   Float
  cargaEntregada  Float @default(0)

  rutaPlanificada String?

  ruta            Ruta?

  fechaCreacion   DateTime @default(now())
}

/*
|--------------------------------------------------------------------------
| RUTA
|--------------------------------------------------------------------------
*/

model Ruta {
  id              String   @id @default(uuid())

  asignacionId    String   @unique
  asignacion      Asignacion @relation(fields: [asignacionId], references: [id])

  estado          String

  // 🆕 nuevos campos
  horaInicio      DateTime?
  horaFin         DateTime?

  eventos         RutaEvento[]
  incidencias     Incidencia[]
}

/*
|--------------------------------------------------------------------------
| EVENTOS DE RUTA
|--------------------------------------------------------------------------
*/

model RutaEvento {
  id          String   @id @default(uuid())

  rutaId      String
  ruta        Ruta     @relation(fields: [rutaId], references: [id])

  tipo        String
  descripcion String

  metadata    Json?

  fecha       DateTime @default(now())
}

/*
|--------------------------------------------------------------------------
| INCIDENCIA
|--------------------------------------------------------------------------
*/

model Incidencia {
  id              String   @id @default(uuid())

  rutaId          String
  ruta            Ruta     @relation(fields: [rutaId], references: [id])

  estado          String
  tipo            String
  descripcion     String
  gravedad        String

  danoEstimado    Float?

  reportadoPor    String

  acciones        IncidenciaAccion[]

  fechaCreacion   DateTime @default(now())
  fechaCierre     DateTime?
  cerradoPor      String?
}

/*
|--------------------------------------------------------------------------
| ACCIONES DE INCIDENCIA
|--------------------------------------------------------------------------
*/

model IncidenciaAccion {
  id              String   @id @default(uuid())

  incidenciaId    String
  incidencia      Incidencia @relation(fields: [incidenciaId], references: [id])

  tipo            String
  descripcion     String
  realizadaPor    String

  metadata        Json?

  fecha           DateTime @default(now())
}

/*
|--------------------------------------------------------------------------
| USUARIO
|--------------------------------------------------------------------------
*/

enum RolUsuario {
  ADMIN
  FLEET_MANAGER
  INCIDENT_MANAGER
  REQUEST_MANAGER
  DRIVER
}

model Usuario {
  id           String @id @default(uuid())

  email        String @unique

  passwordHash String

  nombre       String

  rol          RolUsuario

  sucursalId   String?
  sucursal     Sucursal? @relation(fields: [sucursalId], references: [id])

  conductorId  String? @unique
  conductor    Conductor? @relation(fields: [conductorId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}